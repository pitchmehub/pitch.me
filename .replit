modules = ["nodejs-20", "python-3.12", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"
packages = ["cargo", "file", "freetype", "glibcLocales", "libiconv", "libxcrypt", "openssl", "pkg-config", "rustc"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Frontend"

[[workflows.workflow]]
name = "Backend"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && gunicorn --bind=0.0.0.0:8000 --workers 2 'app:create_app()'"
waitForPort = 8000

[[workflows.workflow]]
name = "Frontend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "cd backend && gunicorn --bind=127.0.0.1:8000 'app:create_app()' --workers 2 & cd frontend && npm run preview -- --port 5000 --host 0.0.0.0"]
build = ["bash", "-c", "cd frontend && npm install && npm run build"]

[userenv]

[userenv.shared]
FLASK_SECRET_KEY = "f6f9e954ce438fc718b4e8333fc0c68784aee8e2faf2e026bd8473dee7e77901"
PII_ENCRYPTION_KEY = "RL8flgxD1qcK8eIIBvuoCYKP11I9nQ5F2GtXJonGLG8"
FLASK_ENV = "development"
ALLOWED_ORIGINS = "http://localhost:5000"
FRONTEND_URL = "http://localhost:5000"
SAQUE_CRON_SECRET = "EQJ5f5wFHYrGH52sZ2JI8Lw4FkvS5vItPEEiZ16MpGU"
